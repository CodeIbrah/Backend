{
  "name": "backend-template",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "main",
    "microservices/auth-service",
    "microservices/users-service",
    "microservices/notifications-service",
    "microservices/payment-service",
    "microservices/invoice-service",
    "microservices/mail-service",
    "microservices/sms-service",
    "packages/*"
  ],
  "description": "Enterprise-ready backend template with hybrid monolith + microservices architecture",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "node scripts/dev.js",
    "dev:all": "node scripts/dev-all.js",
    "dev:main": "npm run dev -w main",
    "dev:auth": "npm run dev -w microservices/auth-service",
    "dev:users": "npm run dev -w microservices/users-service",
    "dev:payments": "npm run dev -w microservices/payment-service",
    "dev:notifications": "npm run dev -w microservices/notifications-service",
    "dev:invoice": "npm run dev -w microservices/invoice-service",
    "dev:mail": "npm run dev -w microservices/mail-service",
    "dev:sms": "npm run dev -w microservices/sms-service",
    "build": "npm run build -w main && npm run build -w microservices/auth-service && npm run build -w microservices/users-service && npm run build -w microservices/notifications-service && npm run build -w microservices/payment-service && npm run build -w microservices/invoice-service && npm run build -w microservices/mail-service && npm run build -w microservices/sms-service",
    "health": "node scripts/check-health.js",
    "lint": "npm run lint -w main",
    "test": "npm run test -w main",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "pg": "^8.21.0",
    "stripe": "^22.1.1"
  }
}
