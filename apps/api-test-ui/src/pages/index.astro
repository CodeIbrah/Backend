---
import Layout from '@/layouts/Layout.astro';
---

<Layout>
  <div class="flex h-screen overflow-hidden bg-surface-950 text-surface-100">
    <!-- Sidebar -->
    <aside
      id="sidebar"
      class="w-[280px] flex-shrink-0 border-r border-surface-700 overflow-y-auto transition-all duration-150 ease-in-out"
    >
      <!-- Populated by sidebar.ts -->
    </aside>

    <!-- Main content -->
    <main class="flex-1 flex flex-col overflow-hidden min-w-0">
      <!-- Tab bar -->
      <div
        id="tab-bar"
        class="flex items-center justify-between px-4 pt-3 pb-2 border-b border-surface-700 bg-surface-900/50"
      >
        <div class="flex items-center gap-1">
          <button
            data-tab="request"
            class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium border-b-2 transition-colors text-brand-500 border-brand-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
              <path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4Z"/>
            </svg>
            Request
          </button>
          <button
            data-tab="tests"
            class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium border-b-2 transition-colors text-surface-400 border-transparent hover:text-surface-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
              <path d="M4 4v16h16"/><path d="m22 2-9 9 4 4"/><path d="M6 14c2 0 4-2 6-2s4 2 6 2"/><path d="M6 10c2 0 4-2 6-2s4 2 6 2"/>
            </svg>
            Tests
          </button>
          <button
            data-tab="docs"
            class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium border-b-2 transition-colors text-surface-400 border-transparent hover:text-surface-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/>
            </svg>
            Docs
          </button>
          <button
            data-tab="logs"
            class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium border-b-2 transition-colors text-surface-400 border-transparent hover:text-surface-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
              <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
            Logs
          </button>
        </div>

        <!-- Connection status -->
        <div id="connection-status"></div>
      </div>

      <!-- View: Request -->
      <div data-view="request-view" class="flex-1 overflow-y-auto p-4 space-y-4">
        <div id="request-panel" class="max-w-4xl mx-auto w-full"></div>
        <div id="response-panel" class="max-w-4xl mx-auto w-full"></div>
      </div>

      <!-- View: Tests -->
      <div data-view="tests-view" class="flex-1 overflow-y-auto p-4 hidden">
        <div id="test-runner"></div>
      </div>

      <!-- View: Docs -->
      <div data-view="docs-view" class="flex-1 overflow-y-auto p-4 hidden">
        <div id="docs-viewer"></div>
      </div>

      <!-- View: Logs -->
      <div data-view="logs-view" class="flex-1 overflow-hidden hidden">
        <div id="logs-viewer" class="h-full"></div>
      </div>
    </main>
  </div>

  <script>
    import '@/scripts/app';
  </script>
</Layout>
