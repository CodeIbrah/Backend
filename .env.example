# Application
NODE_ENV=development
PORT=3000
APP_NAME=backend-template
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/backend_db?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT (min 16 chars, min 32 chars in production)
# Generate: openssl rand -hex 32
JWT_SECRET=your-secure-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OpenTelemetry
OTEL_SERVICE_NAME=backend-template
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# AI Provider
AI_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Alerts
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL=

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_FLUSH_INTERVAL=10000

# Queue
BULLMQ_PREFIX=backend-template

# Auto Recovery
AUTO_RECOVERY_ENABLED=true
AUTO_RECOVERY_MAX_RETRIES=3

# Microservice URLs
PAYMENT_SERVICE_URL=http://localhost:3004
INVOICE_SERVICE_URL=http://localhost:3006
MAIL_SERVICE_URL=http://localhost:3007
SMS_SERVICE_URL=http://localhost:3008

# Internal Service Auth
INTERNAL_API_KEY=internal-key-change-in-production

# Mail Service (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@example.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Security
METRICS_API_KEY=your-metrics-api-key-here
ALLOWED_METRICS_IPS=127.0.0.1,::1
