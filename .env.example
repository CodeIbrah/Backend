# Application
NODE_ENV=development
PORT=3000
APP_NAME=backend-template
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/backend_db?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT (min 16 chars, min 32 chars in production)
# Generate: openssl rand -hex 32
JWT_SECRET=your-secure-secret-at-least-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OpenTelemetry
OTEL_SERVICE_NAME=backend-template
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# AI Provider
AI_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Alerts
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL=

# Encryption (AES-256-GCM at rest)
# Used by CipherService to encrypt OAuth tokens, PII, and sensitive payloads.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# TLS / HTTPS (optional)
# Provide PEM file paths to enable direct HTTPS. In production behind a reverse
# proxy (nginx, Cloud Run, ELB) TLS typically terminates at the proxy.
SSL_KEY_PATH=
SSL_CERT_PATH=
SSL_CA_PATH=

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_FLUSH_INTERVAL=10000

# Queue
BULLMQ_PREFIX=backend-template

# Auto Recovery
AUTO_RECOVERY_ENABLED=true
AUTO_RECOVERY_MAX_RETRIES=3

# === Optional Modules ===

# Cache (Redis)
# Disable: set CACHE_ENABLED=false or remove REDIS_URL
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300

# Audit Trail (database)
# Tracks CRUD operations on entities via AuditService.log()
# Disable: set AUDIT_ENABLED=false
AUDIT_ENABLED=true

# gRPC server
# Enables optional gRPC endpoint on the configured port
# Requires: @nestjs/microservices
# Disable: set GRPC_ENABLED=false
GRPC_ENABLED=false
GRPC_PORT=50051

# === Social Login (OAuth2) ===
# Each provider is optional — only configure the ones you need.

# Google OAuth2
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/google/callback

# Meta (Facebook) OAuth2
# https://developers.facebook.com/apps
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/meta/callback

# Microsoft Identity Platform
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common  # or your tenant ID
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/microsoft/callback

# GitHub OAuth2
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/github/callback

# GitLab OAuth2
# https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/gitlab/callback
GITLAB_BASE_URL=https://gitlab.com  # or self-hosted URL

# Apple Sign In
# https://developer.apple.com/account/resources/identifiers/list/service
APPLE_CLIENT_ID=           # Service ID or Bundle ID
APPLE_TEAM_ID=             # Apple Developer Team ID
APPLE_KEY_ID=              # Key ID from Apple Developer
APPLE_PRIVATE_KEY=         # Content of the .p8 private key file (ES256)
APPLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/social/apple/callback

# Metrics
METRICS_API_KEY=your-metrics-api-key-here
ALLOWED_METRICS_IPS=127.0.0.1,::1
